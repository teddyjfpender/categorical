---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-border px-6 py-4">
      <nav class="max-w-6xl mx-auto flex items-center justify-between" aria-label="Main navigation">
        <a href="/" class="flex items-center gap-2 text-xl font-semibold" aria-label="Categorical home">
          <span class="text-accent">C</span>ategorical
        </a>
        <div class="flex items-center gap-6 text-sm text-text-secondary">
          <a href="/type-systems/basic-types" class="hover:text-text-primary transition-colors duration-150 py-1">Lessons</a>
          <a href="/dashboard" class="hover:text-text-primary transition-colors duration-150 py-1">Dashboard</a>
        </div>
      </nav>
    </header>

    <!-- Hero -->
    <main class="flex-1 flex items-center justify-center px-6">
      <div class="max-w-3xl text-center">
        <div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-border text-sm text-text-secondary">
          Interactive Haskell learning platform
        </div>
        <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
          Master <span class="text-accent">type systems</span> and
          <span class="text-accent">category theory</span>
          through Haskell
        </h1>
        <p class="text-lg md:text-xl text-text-secondary mb-10 max-w-2xl mx-auto leading-relaxed">
          Hands-on exercises with an embedded code editor, instant compiler feedback,
          and a structured curriculum from basic types to advanced abstractions.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a
            href="/type-systems/basic-types"
            class="px-6 py-3 bg-accent hover:bg-accent-bright active:bg-accent-dim text-white font-medium rounded-lg transition-colors duration-150"
          >
            Start Learning
          </a>
          <a
            href="/dashboard"
            class="px-6 py-3 border border-border hover:border-border-bright hover:bg-bg-hover active:bg-bg-tertiary text-text-secondary hover:text-text-primary rounded-lg transition-colors duration-150"
          >
            View Curriculum
          </a>
        </div>

        <!-- Module Cards -->
        <div class="mt-20 grid md:grid-cols-3 gap-4 text-left">
          <a href="/type-systems/basic-types" class="group p-6 rounded-xl bg-bg-card border border-border hover:border-border-bright hover:bg-bg-hover transition-colors duration-150">
            <div class="text-2xl mb-3" aria-hidden="true">&#x03BB;</div>
            <h3 class="font-semibold mb-2 group-hover:text-accent transition-colors duration-150">Type Systems</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              From basic types and ADTs to GADTs, type families, and dependent types.
            </p>
          </a>
          <a href="/category-theory/functors" class="group p-6 rounded-xl bg-bg-card border border-border hover:border-border-bright hover:bg-bg-hover transition-colors duration-150">
            <div class="text-2xl mb-3" aria-hidden="true">&#x2219;</div>
            <h3 class="font-semibold mb-2 group-hover:text-accent transition-colors duration-150">Category Theory</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Functors, natural transformations, monads, and adjunctions — through code.
            </p>
          </a>
          <div class="p-6 rounded-xl bg-bg-card border border-border opacity-60">
            <div class="text-2xl mb-3" aria-hidden="true">&#x03B1;</div>
            <h3 class="font-semibold mb-2">Functional Algorithms</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Recursion schemes, persistent data structures, and algebraic approaches.
            </p>
            <span class="inline-block mt-3 text-[10px] text-text-muted uppercase tracking-wider font-medium">Coming soon</span>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-border px-6 py-6">
      <div class="max-w-6xl mx-auto text-center text-sm text-text-muted">
        Categorical — Learn Haskell through types, categories, and code.
      </div>
    </footer>
  </div>
</BaseLayout>
