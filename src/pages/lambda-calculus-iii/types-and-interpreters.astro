---
import WorkspaceLayout from '../../layouts/WorkspaceLayout.astro';
import { getCollection } from 'astro:content';
import { getExercisesByModule } from '../../lib/exercises';

const lessons = await getCollection('lessons');
const lesson = lessons.find(l => l.id === 'lambda-calculus-iii/types-and-interpreters');

if (!lesson) {
  return Astro.redirect('/');
}

const exercises = getExercisesByModule('lambda-calculus-iii');
---

<WorkspaceLayout
  title={lesson.data.title}
  module={lesson.data.module}
  moduleTitle={lesson.data.moduleTitle}
  lessonSlug="types-and-interpreters"
  exercises={exercises}
  lessonContent=""
  description={lesson.data.description}
/>
