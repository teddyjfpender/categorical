---
import WorkspaceLayout from '../../layouts/WorkspaceLayout.astro';
import { getCollection } from 'astro:content';
import { getExercisesByModule } from '../../lib/exercises';

const lessons = await getCollection('lessons');
const lesson = lessons.find(l => l.id === 'rust-ownership-borrowing/ownership');

if (!lesson) {
  return Astro.redirect('/');
}

const exercises = getExercisesByModule('rust-ownership-borrowing');
---

<WorkspaceLayout
  title={lesson.data.title}
  module={lesson.data.module}
  moduleTitle={lesson.data.moduleTitle}
  lessonSlug="ownership"
  exercises={exercises}
  lessonContent=""
  description={lesson.data.description}
/>
