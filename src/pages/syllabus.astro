---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/paths';
---

<BaseLayout title="Syllabus">
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-border px-6 py-4">
      <nav class="max-w-6xl mx-auto flex items-center justify-between" aria-label="Main navigation">
        <a href={href('/')} class="flex items-center gap-2 text-xl font-semibold" aria-label="Categorical home">
          <span class="text-accent font-mono">C</span>ategorical
        </a>
        <div class="flex items-center gap-6 text-sm text-text-secondary">
          <a href={href('/syllabus')} class="text-text-primary">Syllabus</a>
          <a href={href('/dashboard')} class="hover:text-text-primary transition-colors duration-150 py-1">Dashboard</a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl mx-auto w-full px-6 py-10">
      <h1 class="text-3xl font-bold mb-2">Curriculum</h1>
      <p class="text-text-secondary mb-6">Programming taste across the stack: find structure first, encode invariants, then let algorithms and interpreters carry the implementation.</p>

      <div class="mb-8 rounded-lg border border-border bg-bg-card p-4">
        <div class="grid sm:grid-cols-3 gap-4">
          <div>
            <div class="text-xs font-medium text-text-primary mb-1">Human judgment</div>
            <p class="text-xs text-text-muted leading-relaxed">Choose the domain shape: operations, laws, invariants, and valid transitions.</p>
          </div>
          <div>
            <div class="text-xs font-medium text-text-primary mb-1">Algorithmic taste</div>
            <p class="text-xs text-text-muted leading-relaxed">Pick the composition strategy that matches the data, runtime, and failure model.</p>
          </div>
          <div>
            <div class="text-xs font-medium text-text-primary mb-1">AI leverage</div>
            <p class="text-xs text-text-muted leading-relaxed">Use constrained types to generate interpreters, tests, refactors, and optimizers.</p>
          </div>
        </div>
      </div>

      <div id="syllabus-root"></div>
    </main>
  </div>

  <script>
    import { createElement } from 'react';
    import { createRoot } from 'react-dom/client';
    import { SyllabusPage } from '../components/syllabus/SyllabusPage';

    const root = document.getElementById('syllabus-root');
    if (root) {
      createRoot(root).render(createElement(SyllabusPage));
    }
  </script>
</BaseLayout>
